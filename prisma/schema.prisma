generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Inventory {
  id              String   @id @default(uuid())
  vehicleDetails  String
  weight          Float
  dateTime        DateTime
  billPaid        Boolean
  createdAt       DateTime @default(now())
}